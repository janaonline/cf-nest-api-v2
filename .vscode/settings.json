{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "eslint.format.enable": true,
  "files.eol": "\n",
  "files.watcherExclude": {
    "**/.history/**": true,
    "**/.cache/**": true,
    "**/cache/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/coverage/**": true,
    "**/.nyc_output/**": true,
    "**/*.tsbuildinfo": true
  },
  "search.exclude": {
    "**/.history/**": true,
    "**/.cache/**": true,
    "**/cache/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/coverage/**": true,
    "**/.nyc_output/**": true,
    "**/*.tsbuildinfo": true
  },
  "files.exclude": {
    "**/.history": true,
    "**/.cache": true,
    "**/cache": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.nyc_output": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
